+      	return -EBUSY;
+    	}
+ 	 }
 
 	unbind_no_pm_drivers_interfaces(udev);
 
@@ -1396,21 +1432,16 @@ int usb_resume(struct device *dev, pm_message_t msg)
 	int			status;
 
 	/*
