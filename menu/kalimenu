f_settings
}

f_startup(){
configfile=/root/.firstrun.option
if [ -e "$configfile" ]; then
	source $configfile
else
	echo "Start up settings not found, exiting to settings menu"
	sleep 5
	f_settings
fi
clear
if [ "$sshonboot" == "1" ]; then
	echo "[X] SSH Set to start up boot"
	read -p "Turn SSH OFF on boot? (y/n): " sshoffboot
	if [ "$sshoffboot" == "y" ]; then 
		sed -i '/sshonboot=1/d' $configfile
		echo "sshonboot=0" >> $configfile
	fi
	echo "SSH will not load on boot"
	sleep 3
else
	echo "[ ] SSH Not set to start on boot"
	read -p "START SSH on boot? (y/n): " sshonboot
	if [ "$sshonboot" == "y" ]; then
		sed -i '/sshonboot=0/d' $configfile 
		echo "sshonboot=1" >> $configfile
	fi
	echo "SSH will load on boot"
	sleep 3
fi

if [ "$vnconboot" == "1" ]; then
	echo "[X] VNC Set to start up on boot"
	read -p "Turn VNC OFF on boot? (y/n): " vncoffboot
	if [ "$vncoffboot" == "y" ]; then 
		sed -i '/vnconboot=1/d' $configfile 
		echo "vnconboot=0" >> $configfile
	fi
	echo "VNC will not load on boot"
	sleep 3
else
	echo "[ ] VNC Not set to start on boot"
	read -p "START VNC on boot? (y/n): " vnconboot
	if [ "$vnconboot" == "y" ]; then 
		sed -i '/vnconboot=0/d' $configfile 
		echo "vnconboot=1" >> $configfile
	fi
	echo "VNC will load on boot"
	sleep 3
fi
f_settings
}

f_msuser() {
	service postgresql start
	echo "Switching to user postgres"
	su postgres	
	read -p "Enter Metasploit database username:" msuser
	createuser -D -P -R -S $msuser
	read -p "Enter Metasploit database name:" dbname
	createdb --owner=$msuser $dbname
	su root
	echo "You can now add database connection to startup at ~/.msf4/msfconsole.rc"
	echo "Add:"
	echo "db_connect $msuser:YOURPASSWORD@127.0.0.1:5432/$dbname"
	sleep 4
	f_settings
}

f_macchanger(){
# make sure ifconfig wlan1 is up already
adaptor=`ip addr | grep wlan1`
if [ -z "$adaptor" ]; then
    ifconfig wlan1 up
fi
f_pick_interface
read -p "Use random MAC address on ${pickinterface}? (y/n)" randommac
if [ "$randommac" == "y" ]; then
	macchanger --random $pickinterface
	else
		read -p "Would you like to set a specific MAC address for ${pickinterface}?" specificmac
		if [ "$specificmac" == "y" ]; then
			read -p "Enter your specific MAC address: " spec_evil_mac
			macchanger --mac=$spec_evil_mac $pickinterface
		fi
fi
f_settings
}

