f_nodejs(){
cd /tmp
echo "Downloading install script"
wget https://raw.github.com/creationix/nvm/master/install.sh && chmod +x install.sh
source ~/.nvm/nvm.sh
echo "Starting NodeJS install.  This will take a while..."
sleep 5
nvm install 0.11.11
