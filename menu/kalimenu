f_wlan1check(){
adaptor=`ip addr | grep wlan1`
if [ -z "$adaptor" ]; then
    ifconfig wlan1 up
    sleep 2
    echo "Attempting to bring wlan1 up"
    	if [ -z "$adaptor" ]; then
    		echo "Still not detecting wlan1, please try plugging it in again."
    		sleep 5
    		clear
    		echo "WLAN1: NOT FOUND"
    		echo ""
    	fi
else
	echo "WLAN1: FOUND" 
	echo ""
fi
}

